generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  name           String
  role           String    @default("USER")
  workspaceId    String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  sessions       Session[]
  accounts       Account[]

  @@index([workspaceId])
}

model Workspace {
  id             String           @id @default(cuid())
  name           String           @unique
  webhookToken   String           @unique @default(cuid())
  lgmApiKey      String?
  lgmCampaignId  String?
  lgmAudiences   String?          @default("[]")
  lgmIdentityId  String?
  lgmMemberId    String?
  aiProvider     String?
  claudeApiKey   String?
  geminiApiKey   String?
  groqApiKey     String?
  openaiApiKey   String?
  mantiksApiKey  String?
  apolloApiKey   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  users          User[]
  jobOffers      JobOffer[]
  customFields   CustomFieldDef[]
  mantikSearches MantikSearch[]
}

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model JobOffer {
  id                  String    @id @default(cuid())
  workspaceId         String

  // Offre d'emploi
  title               String
  description         String?
  url                 String?

  // Entreprise
  company             String
  linkedinPage        String?
  website             String?
  phone               String?
  headquarters        String?

  // Offre
  offerLocation       String?
  source              String?
  publishedAt         DateTime?
  receivedAt          DateTime  @default(now())

  // Lead
  leadCivility        String?
  leadFirstName       String?
  leadLastName        String?
  leadEmail           String?
  leadJobTitle        String?
  leadLinkedin        String?
  leadPhone           String?

  // Action
  toContact           Boolean   @default(false)
  doNotContact        Boolean   @default(false)
  contactedAt         DateTime?
  lgmSent             Boolean   @default(false)
  lgmSentAt           DateTime?
  lgmAudience         String?
  phoneLookupRequested Boolean  @default(false)
  enrichedPhone       String?
  apolloEnrichmentStatus String @default("not_requested")

  // Stats LGM (via sync API)
  lgmLeadId           String?
  lgmMessagesSent     Int?
  lgmEmailOpened      Int?

  // Événements LGM (via webhook)
  lgmConnectionSentAt      DateTime?
  lgmConnectionAcceptedAt  DateTime?
  lgmMessage1SentAt        DateTime?
  lgmRepliedAt             DateTime?
  lgmReplyContent          String?
  lgmEvents                String?   @default("[]")

  // Champs personnalisés (JSON stocké en texte pour SQLite)
  customValues        String    @default("{}")

  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([toContact])
  @@index([receivedAt])
}

model MantikSearch {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  filters     String    // JSON
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model CustomFieldDef {
  id        String   @id @default(cuid())
  workspaceId    String
  name      String
  label     String
  type         String   @default("TEXT")
  formula      String?
  lgmAttribute String?
  autoFill     Boolean  @default(false)
  order        Int      @default(0)
  createdAt DateTime @default(now())

  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
}
