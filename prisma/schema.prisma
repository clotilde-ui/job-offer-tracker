generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  name           String
  role           String    @default("USER")
  webhookToken   String    @unique @default(cuid())
  lgmApiKey      String?
  lgmCampaignId  String?

  aiProvider     String?
  claudeApiKey   String?
  geminiApiKey   String?
  groqApiKey     String?
  openaiApiKey   String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  jobOffers      JobOffer[]
  customFields   CustomFieldDef[]

  sessions       Session[]
  accounts       Account[]
}

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model JobOffer {
  id                  String    @id @default(cuid())
  userId              String

  // Offre d'emploi
  title               String
  description         String?
  url                 String?

  // Entreprise
  company             String
  linkedinPage        String?
  website             String?
  phone               String?
  headquarters        String?

  // Offre
  offerLocation       String?
  source              String?
  publishedAt         DateTime?
  receivedAt          DateTime  @default(now())

  // Lead
  leadCivility        String?
  leadFirstName       String?
  leadLastName        String?
  leadEmail           String?
  leadJobTitle        String?
  leadLinkedin        String?
  leadPhone           String?

  // Action
  toContact           Boolean   @default(false)
  contactedAt         DateTime?
  lgmSent             Boolean   @default(false)

  // Champs personnalisés (JSON stocké en texte pour SQLite)
  customValues        String    @default("{}")

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([toContact])
  @@index([receivedAt])
}

model CustomFieldDef {
  id        String   @id @default(cuid())
  userId    String
  name      String
  label     String
  type      String   @default("TEXT")
  formula   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}
